rules_version = '2';

// Craft rules based on data in your Firestore database
// allow write: if firestore.get(
//    /databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin;
service firebase.storage {
  match /b/{bucket}/o {
    
    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Properties Images (Users can read, Authenticated Agents can upload)
    match /properties/{propertyId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null 
                   && request.resource.size < 5 * 1024 * 1024 // Max 5MB
                   && request.resource.contentType.matches('image/.*'); // Only images
    }

    // Users Avatars & Cover Photos
    match /users/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null 
                   && request.auth.uid == userId // Only the user can upload their own files
                   && request.resource.size < 5 * 1024 * 1024 // Max 5MB for avatars/covers
                   && request.resource.contentType.matches('image/.*'); // Only images
    }
  }
}
