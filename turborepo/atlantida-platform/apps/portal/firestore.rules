rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper — contar posts de hoy
    function getPostsToday(uid) {
      let oneDayAgo = request.time - duration.value(86400, 's');
      return getAfter(/databases/$(database)/documents/feedPosts)
        .where('authorId', '==', uid)
        .where('createdAt', '>=', oneDayAgo)
        .size();
    }

    // Properties Collection
    match /properties/{propertyId} {
      allow read: if true;

      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.title.size() >= 10 &&
                      request.resource.data.title.size() <= 200 &&
                      request.resource.data.price > 0 &&
                      request.resource.data.images.size() >= 1 &&
                      request.resource.data.images.size() <= 20;

      allow update: if isOwner(resource.data.userId) || isAdmin() || 
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']));

      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // Users Collection
    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    // Leads Collection
    match /leads/{leadId} {
      allow read: if isAuthenticated() &&
                    (resource.data.agentId == request.auth.uid || isAdmin());

      allow create: if request.resource.data.leadName.size() > 0 &&
                      request.resource.data.leadEmail.matches('.*@.*\\..*') &&
                      request.resource.data.leadMessage.size() >= 10;

      allow update, delete: if false;
    }

    // Saved Searches Collection
    match /savedSearches/{searchId} {
      allow read, write: if isAuthenticated() &&
                           resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid;
    }

    // Notifications Collection (future)
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() &&
                    resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // Feed Posts Collection
    match /feedPosts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated() 
        && request.resource.data.authorId == request.auth.uid
        && getPostsToday(request.auth.uid) < 5;
      allow update: if isAuthenticated() && (
        isOwner(resource.data.authorId) || 
        isAdmin() || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'rankingScore', 'whatsappClicks', 'comments'])
      );
      allow delete: if isOwner(resource.data.authorId) || isAdmin();
    }
  }
}
