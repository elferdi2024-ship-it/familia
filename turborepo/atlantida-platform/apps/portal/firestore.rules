rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Límite 5 posts/día: aplicado en cliente (CreatePostModal) y/o API; en reglas no es posible hacer query+count.

    // Properties Collection
    match /properties/{propertyId} {
      allow read: if true;

      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.title.size() >= 10 &&
                      request.resource.data.title.size() <= 200 &&
                      request.resource.data.price > 0 &&
                      request.resource.data.images.size() >= 1 &&
                      request.resource.data.images.size() <= 20;

      allow update: if isOwner(resource.data.userId) || isAdmin() || 
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']));

      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // Users Collection
    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    // Leads Collection
    match /leads/{leadId} {
      allow read: if isAuthenticated() &&
                    (resource.data.agentId == request.auth.uid || isAdmin());

      allow create: if request.resource.data.leadName.size() > 0 &&
                      request.resource.data.leadEmail.matches('.*@.*\\..*') &&
                      request.resource.data.leadMessage.size() >= 10;

      allow update: if isAuthenticated() &&
                    (resource.data.agentId == request.auth.uid || isAdmin());
      allow delete: if false;
    }

    // Conversations (chat interno)
    match /conversations/{convId} {
      allow read: if isAuthenticated() &&
        (resource.data.agentId == request.auth.uid || resource.data.leadId == request.auth.uid);
      allow create: if isAuthenticated() &&
        request.resource.data.leadId == request.auth.uid &&
        request.resource.data.agentId is string;
      allow update: if isAuthenticated() &&
        (resource.data.agentId == request.auth.uid || resource.data.leadId == request.auth.uid);
      allow delete: if false;
    }
    match /conversations/{convId}/messages/{msgId} {
      allow read: if isAuthenticated() &&
        (get(/databases/$(database)/documents/conversations/$(convId)).data.agentId == request.auth.uid ||
         get(/databases/$(database)/documents/conversations/$(convId)).data.leadId == request.auth.uid);
      allow create: if isAuthenticated() &&
        (get(/databases/$(database)/documents/conversations/$(convId)).data.agentId == request.auth.uid ||
         get(/databases/$(database)/documents/conversations/$(convId)).data.leadId == request.auth.uid);
      allow update, delete: if false;
    }

    // Lead Notes (CRM Pro/Premium)
    match /lead_notes/{noteId} {
      allow read, write: if isAuthenticated() &&
        resource.data.agentId == request.auth.uid;
      allow create: if isAuthenticated() &&
        request.resource.data.agentId == request.auth.uid;
    }

    // Saved Searches Collection
    match /savedSearches/{searchId} {
      allow read, write: if isAuthenticated() &&
                           resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid;
    }

    // Notifications Collection (future)
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() &&
                    resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // Config (launch: contador Fundadores) — lectura pública para el banner; escritura solo admin
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Corporate leads (formulario plan corporativo)
    match /corporate_leads/{leadId} {
      allow read: if isAdmin();
      allow create: if request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.email is string
                    && request.resource.data.email.matches('.*@.*\\..*')
                    && request.resource.data.range is string
                    && request.resource.data.range.size() > 0;
      allow update, delete: if isAdmin();
    }

    // Feed Posts Collection (límite 5/día aplicado en cliente/API)
    match /feedPosts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.authorId == request.auth.uid;
      allow update: if isAuthenticated() && (
        isOwner(resource.data.authorId) || 
        isAdmin() || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'rankingScore', 'whatsappClicks', 'comments'])
      );
      allow delete: if isOwner(resource.data.authorId) || isAdmin();
    }
  }
}
