// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OperationType {
  Venta
  Alquiler
  Alquiler_Temporal @map("Alquiler Temporal")
}

enum PropertyType {
  Casa
  Apartamento
  Terreno
  Local_Comercial   @map("Local Comercial")
  Oficina
  Chacra_o_Campo     @map("Chacra o Campo")
  Garaje_o_Cochera   @map("Garaje o Cochera")
}

model Property {
  id          String        @id @default(uuid()) @db.Uuid
  slug        String        @unique
  title       String
  description String        @db.Text
  
  operation   OperationType
  type        PropertyType
  
  price       Decimal       @db.Decimal(12, 2)
  currency    String        @default("USD")
  
  // Location details
  department  String
  city        String
  neighborhood String
  address     String?
  lat         Float?
  lng         Float?
  
  // Features
  bedrooms    Int           @default(0)
  bathrooms   Int           @default(0)
  area        Int           // m2 totales
  builtArea   Int?          // m2 construidos
  garages     Int           @default(0)
  
  // Media
  images      String[]      // URLs from Cloud Storage
  
  // Metadata
  featured    Boolean       @default(false)
  status      String        @default("active") // active, pending, sold
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  // Relationship (Optional if you add Auth later)
  userId      String?
  
  @@index([operation, type])
  @@index([neighborhood])
  @@index([price])
}
