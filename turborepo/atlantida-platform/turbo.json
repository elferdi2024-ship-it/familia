{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        ".env*"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ],
      "cache": true
    },
    "typecheck": {
      "dependsOn": [
        "^typecheck"
      ],
      "cache": true
    },
    "test": {
      "dependsOn": [
        "^build"
      ],
      "cache": false
    },
    "test:run": {
      "dependsOn": [
        "^build"
      ],
      "cache": true
    },
    "clean": {
      "cache": false
    }
  },
  "globalEnv": [
    "NEXT_PUBLIC_FIREBASE_*",
    "NEXT_PUBLIC_ALGOLIA_*",
    "NEXT_PUBLIC_GOOGLE_MAPS_*",
    "SENTRY_*",
    "RESEND_*",
    "ALGOLIA_ADMIN_KEY"
  ]
}